# Required: The Cribl Stream instance URL (e.g., https://your-cribl-instance:10080)
CRIBL_URL=https://your-cribl-instance:10080

# Optional: The auth token configured in the Cribl HTTP source
CRIBL_TOKEN=your-auth-token

# Optional: Source value for events
CRIBL_SOURCE=loglayer

# Optional: Host value for events
CRIBL_HOST=

# Optional: Max number of retries
CRIBL_MAX_RETRIES=3

# Optional: Retry delay in ms
CRIBL_RETRY_DELAY=1000

# Optional: Respect rate limiting (true/false)
CRIBL_RESPECT_RATE_LIMIT=true

# Optional: Enable batch sending (true/false)
CRIBL_ENABLE_BATCH=true

# Optional: Batch size
CRIBL_BATCH_SIZE=100

# Optional: Batch send timeout in ms
CRIBL_BATCH_TIMEOUT=5000
