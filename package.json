{
  "name": "loglayer-monorepo",
  "description": "",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "add-changeset": "changeset add",
    "docs": "cd docs && pnpm run docs:dev",
    "docs:build": "cd docs && pnpm run docs:build",
    "changeset": "changeset",
    "clean": "bash scripts/clean.sh",
    "clean:all": "bash scripts/clean.sh --all",
    "clean:repo": "git add --all && git reset --hard",
    "commitlint": "commitlint",
    "lint:packages": "pnpm run lint:packages:semver && pnpm run lint:packages:mismatches",
    "lint:packages:semver": "syncpack lint",
    "lint:packages:mismatches": "syncpack lint",
    "publish-packages": "turbo run build && changeset version && changeset publish",
    "typecheck": "turbo run verify-types --continue --",
    "syncpack:update": "syncpack update --interactive && syncpack fix && pnpm i",
    "syncpack:format": "syncpack format",
    "syncpack:lint": "syncpack lint",
    "release": "git config user.name \"github-actions[bot]\" && git config user.email \"github-actions[bot]@users.noreply.github.com\" && changeset publish",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@internal/tsconfig": "workspace:*",
    "@types/node": "25.9.1",
    "lefthook": "2.1.8",
    "syncpack": "15.3.1",
    "turbo": "2.9.14",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20.16.0"
  },
  "engineStrict": true,
  "packageManager": "pnpm@10.20.0"
}
